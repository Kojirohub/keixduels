-- Auto Movement
-- ========== GALAXY AUTO MOVEMENT (waypoint system) ==========
local galaxyWaypoints = {}
local galaxyCurrentWaypoint = 1
local galaxyMoving = false
local galaxyConnection = nil
local isAutoRightActive = false
local isAutoLeftActive = false

local function galaxyMoveToWaypoint()
    if galaxyConnection then galaxyConnection:Disconnect() end
    galaxyConnection = RunService.Stepped:Connect(function()
        if not galaxyMoving then return end
        local character = LocalPlayer.Character
        local rp = character and character:FindFirstChild("HumanoidRootPart")
        if not rp or #galaxyWaypoints == 0 then return end

        local targetPos = galaxyWaypoints[galaxyCurrentWaypoint].position
        local wpSpeed = galaxyWaypoints[galaxyCurrentWaypoint].speed or 29
        local distance = (rp.Position - targetPos).Magnitude

        if distance < 5 then
            galaxyCurrentWaypoint = (galaxyCurrentWaypoint % #galaxyWaypoints) + 1
        else
            local direction = (targetPos - rp.Position).Unit
            rp.Velocity = Vector3.new(direction.X * wpSpeed, rp.Velocity.Y, direction.Z * wpSpeed)
        end
    end)
end

local function galaxyStopMoving()
    if galaxyConnection then galaxyConnection:Disconnect() galaxyConnection = nil end
    galaxyMoving = false
    local rp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if rp then rp.Velocity = Vector3.new(0, rp.Velocity.Y, 0) end
end

