        Keybinds[keybindRefName]=kc kbBtn.Text=kc.Name kbBtn.TextColor3=C_PURPLE TweenService:Create(ks,TweenInfo.new(0.15),{Color=C_DIM}):Play() waitingForKey=nil
        if KeybindDisplayLabels[keybindRefName] then KeybindDisplayLabels[keybindRefName].Text=kc.Name end
        if onChanged then onChanged(kc) end
    end)

    local gap=Instance.new("Frame") gap.Size=UDim2.new(1,0,0,5) gap.BackgroundTransparency=1 gap.BorderSizePixel=0 gap.Parent=parent
    return kbBtn
